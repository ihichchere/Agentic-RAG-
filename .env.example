# Copiez ce fichier en `.env` et ajustez si besoin.
# Aucune clé API n'est requise : tout tourne en local via Ollama.

# URL du serveur Ollama local (par défaut, ne pas modifier sauf configuration spécifique)
OLLAMA_BASE_URL=http://localhost:11434

# Modèle de chat Ollama à utiliser (doit avoir été téléchargé avec `ollama pull <modele>`)
# Alternatives possibles : mistral, llama3.2, qwen2.5
CHAT_MODEL=llama3.1

# Modèle d'embedding Ollama (768 dimensions, recommandé pour l'anglais/le multilingue)
EMBEDDING_MODEL=nomic-embed-text

# Température du LLM pour la génération (0 = déterministe, 1 = créatif)
LLM_TEMPERATURE=0.1

# Découpage des documents (en caractères)
CHUNK_SIZE=1000
CHUNK_OVERLAP=150

# Nombre de chunks récupérés par recherche
TOP_K=4

# Boucle d'auto-correction : nombre max de reformulations de requête
MAX_QUERY_REWRITES=2

# Garde-fou LangGraph : nombre max d'étapes exécutées par appel
RECURSION_LIMIT=25
